# ====================================================
# DD Platform — Environment Configuration
# ====================================================
# Copy to .env and fill in your values

# --- Application ---
APP_NAME=DD Platform
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO
HOST=0.0.0.0
PORT=8080

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=your-api-key
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_MAX_RETRIES=3
AZURE_OPENAI_TIMEOUT_SECONDS=60

# --- SurrealDB ---
SURREAL_URL=ws://localhost:8000/rpc
SURREAL_USERNAME=root
SURREAL_PASSWORD=root
SURREAL_NAMESPACE=dd_platform
SURREAL_DATABASE=due_diligence

# --- Tavily ---
TAVILY_API_KEY=your-tavily-api-key
TAVILY_MAX_RESULTS=10
TAVILY_TIMEOUT_SECONDS=30

# --- SerpAPI ---
SERPAPI_API_KEY=your-serpapi-key
SERPAPI_MAX_RESULTS=10
SERPAPI_TIMEOUT_SECONDS=30

# --- Apify ---
APIFY_TOKEN=your-apify-token
APIFY_WEB_SCRAPER_ACTOR_ID=apify/web-scraper
APIFY_TIMEOUT_SECONDS=120

# --- Feature Flags ---
FF_ENABLE_EMBEDDINGS=false
FF_ENABLE_GRAPH_EXPANSION=true
FF_ENABLE_CONTRADICTION_DETECTION=true
FF_DEFAULT_RETRIEVAL_PROFILE=graph_hybrid_expanded
FF_DEFAULT_CHAT_RETRIEVAL_PROFILE=schema_aware_graph_hybrid

# --- Schema ---
ACTIVE_SCHEMA_ID=due_diligence_v1
SCHEMAS_DIR=configs/schemas
PROMPTS_DIR=configs/prompts
RETRIEVAL_PROFILES_DIR=configs/retrieval_profiles
